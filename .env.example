PORT=8000

# Authentication service configuration
AUTH_ORIGIN=https://auth.pallabdev.in
AUTH_CLIENT_ID=your-auth-client-id
AUTH_CLIENT_SECRET=your-auth-client-secret
AUTH_REDIRECT_URI=http://localhost:8000/auth

# Checkbox board behavior
CHECKBOX_COUNT=500
RATE_LIMIT_WINDOW_MS=3000

# Redis connection
# Use REDIS_URL for hosted Redis/Valkey, or REDIS_HOST + REDIS_PORT for local Docker.
# REDIS_URL=redis://localhost:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
